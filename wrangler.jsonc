{
  "name": "handeland",
  "compatibility_date": "2026-06-05",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "www.handeland.dev/*",
      "zone_name": "handeland.dev"
    },
    {
      "pattern": "handeland.dev/*",
      "zone_name": "handeland.dev"
    }
  ],
  "assets": {
    "directory": "./website/public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
